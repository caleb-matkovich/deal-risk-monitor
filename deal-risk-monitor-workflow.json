    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const d = item.json;\n\n  let riskScore = 0;\n  const reasons = [];\n  let recommendedAction = \"No immediate action\";\n\n  // 1) inactivity risk\n  if (d.daysSinceLastActivity >= 14) {\n    riskScore += 30;\n    reasons.push(\"No activity in 14+ days\");\n  } else if (d.daysSinceLastActivity >= 7) {\n    riskScore += 15;\n    reasons.push(\"No activity in 7+ days\");\n  }\n\n  // 2) stage stagnation risk\n  if (d.DaysInStage >= 30) {\n    riskScore += 25;\n    reasons.push(\"Deal stuck in stage for 30+ days\");\n  } else if (d.DaysInStage >= 14) {\n    riskScore += 10;\n    reasons.push(\"Deal aging in current stage\");\n  }\n\n  // 3) next step missing or overdue\n  if (d.nextStepOverdue) {\n    riskScore += 20;\n    reasons.push(\"Next step is missing or overdue\");\n  }\n\n  // 4) close date risk\n  if (d.daysUntilClose < 0) {\n    riskScore += 25;\n    reasons.push(\"Close date already passed\");\n  } else if (d.daysUntilClose <= 7 && d.Stage !== \"Negotiation\" && d.Stage !== \"Closed Won\") {\n    riskScore += 15;\n    reasons.push(\"Close date soon but deal not late-stage\");\n  }\n\n  // 5) bigger deal = more attention\n  if (d.Amount >= 20000) {\n    riskScore += 10;\n    reasons.push(\"High-value deal\");\n  }\n\n  let riskLevel = \"Low\";\n  if (riskScore >= 70) {\n    riskLevel = \"High\";\n    recommendedAction = \"Immediate rep follow-up and manager review\";\n  } else if (riskScore >= 40) {\n    riskLevel = \"Medium\";\n    recommendedAction = \"Rep follow-up within 24 hours\";\n  }\n\n  return {\n    json: {\n      ...d,\n      riskScore,\n      riskLevel,\n      reasons: reasons.join(\"; \"),\n      recommendedAction,\n    }\n  };\n});"
      },
