    {
      "parameters": {
        "jsCode": "const rows = items.map(item => item.json);\n\nif (rows.length === 0) {\n  return [{\n    json: {\n      subject: \"Deal Risk Monitor: No medium/high-risk deals today\",\n      body: \"No medium- or high-risk deals were found in this run.\"\n    }\n  }];\n}\n\nconst lines = rows.map(d => {\n  return [\n    `Deal: ${d.Company} (${d.DealID})`,\n    `Owner: ${d.Owner}`,\n    `Stage: ${d.Stage}`,\n    `Amount: $${d.Amount}`,\n    `Risk Score: ${d.RiskScore || d.riskScore}`,\n    `Risk Level: ${d.RiskLevel || d.riskLevel}`,\n    `Reasons: ${d.Reasons || d.reasons}`,\n    `Recommended Action: ${d.RecommendedAction || d.recommendedAction}`,\n    `---`\n  ].join('\\n');\n});\n\nreturn [{\n  json: {\n    subject: `Deal Risk Monitor: ${rows.length} risky deal(s) detected`,\n    body: lines.join('\\n\\n')\n  }\n}];"
      },
