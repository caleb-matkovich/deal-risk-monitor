    {
      "parameters": {
        "jsCode": "const today = new Date();\n\nfunction daysBetween(dateA, dateB) {\n  const ms = 1000 * 60 * 60 * 24;\n  return Math.floor((dateA - dateB) / ms);\n}\n\nreturn items.map(item => {\n  const d = item.json;\n\n  const amount = Number(d.Amount || 0);\n  const daysInStage = Number(d.DaysInStage || 0);\n\n  const closeDate = d.CloseDate ? new Date(d.CloseDate) : null;\n  const lastActivityDate = d.LastActivityDate ? new Date(d.LastActivityDate) : null;\n  const nextStepDate = d.NextStepDate ? new Date(d.NextStepDate) : null;\n\n  const daysSinceLastActivity = lastActivityDate\n    ? daysBetween(today, lastActivityDate)\n    : 999;\n\n  const daysUntilClose = closeDate\n    ? daysBetween(closeDate, today)\n    : 999;\n\n  const nextStepOverdue = nextStepDate\n    ? today > nextStepDate\n    : true;\n\n  return {\n    json: {\n      ...d,\n      Amount: amount,\n      DaysInStage: daysInStage,\n      daysSinceLastActivity,\n      daysUntilClose,\n      nextStepOverdue,\n      runDate: today.toISOString().split('T')[0],\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        0
      ],
      "id": "fa5a8b14-b1d7-4465-a7c4-239621c07483",
